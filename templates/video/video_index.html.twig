{% extends '@OHMediaBackend/base.html.twig' %}

{% block meta_title %}Videos{% endblock %}

{% block breadcrumbs %}
  {{ bootstrap_breadcrumbs(
    bootstrap_breadcrumb(bootstrap_icon('camera-video') ~ ' Videos', 'video_index'),
  ) }}
{% endblock %}

{% set can_create_video = is_granted(attributes.create, new_video) %}

{% set create_video_href = path('video_create') %}

{% block actions %}
  {% if can_create_video %}
    <a href="{{ create_video_href }}" class="btn btn-primary">
      {{ bootstrap_icon('plus-lg') }}
      Add Video
    </a>
  {% endif %}
{% endblock %}

{% block main %}
  {% set video_count = pagination.count %}

  <div class="card">
    <div class="card-body">
      <div class="card-title card-title-with-count">
        <h1 class="card-title-heading">Videos</h1>
        <div class="card-title-count">
          {{ bootstrap_badge_primary(video_count) }}
        </div>
      </div>

      {% if video_count %}
        <table class="table table-striped">
          <thead>
            <tr>
              <th>&nbsp;</th>
              <th>Video</th>
              <th>Shortcode</th>
              <th>Last Updated</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {% for video in pagination.results %}
              {{ _self.table_row(video, attributes) }}
            {% endfor %}
          </tbody>
        </table>

        {{ bootstrap_pagination(pagination) }}

        <small>{{ bootstrap_pagination_info(pagination) }}</small>
      {% else %}
        <p>
          No videos found.
          {% if can_create_video %}
            <a href="{{ create_video_href }}">Click here to add a video.</a>
          {% endif %}
        </p>
      {% endif %}
    </div>
  </div>
{% endblock %}

{% macro table_row(video, attributes, active_video) %}
  {% set row_actions = [] %}

  {% if is_granted(attributes.edit, video) %}
    {% set row_actions = row_actions|merge([{
      route: 'video_edit',
      route_params: {id: video.id},
      color: 'secondary',
      icon: 'pen',
      text: 'Edit Video',
    }]) %}
  {% endif %}

  {% if is_granted(attributes.delete, video) %}
    {% set row_actions = row_actions|merge([{
      route: 'video_delete',
      route_params: {id: video.id},
      color: 'danger',
      icon: 'trash',
      text: 'Delete Video',
      confirm: 'Are you sure you want to delete this video? Clicking OK will take you to a verification step to delete this entry.',
    }]) %}
  {% endif %}

  <tr>
    <td style="width:150px;">
      {% if video.image and video.image.path %}
        {{ image_tag(video.image, {
          width: 150,
          height: 100,
        }) }}
      {% elseif video.thumbnail %}
        <img src="{{ video.thumbnail }}" />
      {% endif %}
    </td>
    <td>
      <small class="d-block">{{ video.title }}</small>
      {% if video.url %}
      <small class="d-block">
        {% if video.typeVimeo %}
        <i class="bi bi-vimeo" style="color:#00adef"></i>
        {% elseif video.typeYouTube %}
        <i class="bi bi-youtube" style="color:red"></i>
        {% endif %}
        <a href="{{ video.url }}" target="_blank" rel="noopener">{{ video.url }}</a>
      </small>
      {% endif %}
      {% if video.duration %}
      <small class="d-block">
        <b>Duration:</b> {{ video.durationReadable }}
      </small>
      {% endif %}
    </td>
    <td style="width:150px">{{ shortcode('video(' ~ video.id ~ ')') }}</td>
    <td>{{ video.updatedAt|datetime }}</td>
    <td>
      {% include '@OHMediaBackend/widget/row_actions.html.twig' with {
        row_actions: row_actions,
      } only %}
    </td>
  </tr>
{% endmacro %}
